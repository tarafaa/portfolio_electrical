#include <SPI.h>
#include <U8g2lib.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME680.h>

// OLED pin definitions
#define OLED_CS   9
#define OLED_DC   8
#define OLED_RES  7

// BME680 pin definition
#define BME_CS   10

// OLED object
U8G2_SH1106_128X64_NONAME_1_4W_HW_SPI u8g2(
  U8G2_R0,
  /* cs=*/ OLED_CS,
  /* dc=*/ OLED_DC,
  /* reset=*/ OLED_RES
);

// BME680 object
Adafruit_BME680 bme(BME_CS);

// Array settings
const int numReadings = 10;

float tempReading[numReadings];
float gasReading[numReadings];
float pressureReading[numReadings];
float humidityReading[numReadings];

//configure our sensor and OLED
void setup() {
Serial.begin(9600);
delay(1000);

pinMode(OLED_CS, OUTPUT); // we want to output this
pinMode(BME_CS, OUTPUT); // we want to output this

digitalWrite(OLED_CS, HIGH); // set to high in order to turn both of them off for now
digitalWrite(BME_CS, HIGH); 

u8g2.begin();

if(!bme.begin()){ // checking if my bme is conncted

    Serial.println("BME680 in error");
    while(1); // creates an infinite loop if sensor runs into error
}
// samples our data by taking the average of 2 samples
bme.setTemperatureOversampling(BME680_OS_2X);
bme.setHumidityOversampling(BME680_OS_2X);
bme.setPressureOversampling(BME680_OS_4X);
bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
}
void loop() {
for (int i =0; i < numReadings; i++){ // using this to keep track of running through our size 5 array
    digitalWrite(BME_CS, LOW); // Turns BME ON!
    digitalWrite(OLED_CS, HIGH); // Turns OLED off (for now)

if (!bme.performReading()){
    Serial.print("Read failed");
    while(1);
}
// collects sensor value and inserts into index
tempReading[i] = bme.temperature; 
Serial.print("Temperature: ");
Serial.print(tempReading[i]);
Serial.println(" C");
gasReading[i] = bme.gas_resistance / 1000.0; // ohms to kOhms 
Serial.print("Gas Resistance: ");
Serial.print(gasReading[i]);
Serial.println(" kohms");
pressureReading[i] = bme.pressure / 100.0;// Pa to hPa
Serial.print("Pressure: ");
Serial.print(pressureReading[i]);
Serial.println(" hPa");
humidityReading[i] = bme.humidity;
Serial.print("Humidity: ");
Serial.print(humidityReading[i]);
Serial.println(" %");

digitalWrite(BME_CS, HIGH);
delay(500);
}
for(int i =0; i < numReadings; i++) {
u8g2.firstPage();
do {
  u8g2.setFont(u8g2_font_6x10_tr);  // smaller font = more space

  // Title + index
  u8g2.setCursor(0, 10);
  u8g2.print("Reading #");
  u8g2.print(i);

  // Temperature
  u8g2.setCursor(0, 22);
  u8g2.print("Temperature: ");
  u8g2.print(tempReading[i]);
  u8g2.print(" C");

  // Humidity
  u8g2.setCursor(0, 34);
  u8g2.print("Humidity: ");
  u8g2.print(humidityReading[i]);
  u8g2.print(" %");

  // Pressure
  u8g2.setCursor(0, 46);
  u8g2.print("Pressure: ");
  u8g2.print(pressureReading[i]);
  u8g2.print(" hPa");

  // Gas Resistance
  u8g2.setCursor(0, 58);
  u8g2.print("Gas: ");
  u8g2.print(gasReading[i]);
  u8g2.print(" kohm");

} while (u8g2.nextPage());

    delay(1000);
}
}
